# Django Core Configuration
SECRET_KEY=''
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,siem.seclink.info,backend

# PostgreSQL Database Configuration
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CSRF Trusted Origins (comma-separated, no spaces)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Elasticsearch Configuration (optional, for ES integration)
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=your-es-password

# Tickets API (for orchestrator ticket creation)
TICKETS_API_BASE=http://localhost:8000/api/v1/tickets/
TICKETS_API_TOKEN=your-token-here

# frontend environment variable for backend API origin
BACKEND_ORIGIN=http://backend:8000